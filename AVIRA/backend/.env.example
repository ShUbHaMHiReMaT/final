# AVIRA Backend – Environment Variables
# ==========================================
# Copy this file to .env and fill in your keys.
# NEVER commit .env to git.

# ── Flask ─────────────────────────────────
FLASK_ENV=production
SECRET_KEY=change-me-to-a-random-string

# ── NVIDIA NIM API ────────────────────────
# Get your key from: https://build.nvidia.com
# One key works for ALL models listed below.
NVIDIA_API_KEY="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"

# ── NVIDIA NIM Model Names ────────────────
# Master reasoner (reports + LLM analysis)
NVIDIA_MODEL_REASONER=nvidia/llama-3.1-nemotron-ultra-253b-v1

# Fast analysis (disease descriptions, recommendations)
NVIDIA_MODEL_FAST=meta/llama-3.1-8b-instruct

# Structured reasoning (complex multi-step)
NVIDIA_MODEL_STRUCTURED=mistralai/mixtral-8x7b-instruct-v0.1

# Embedding model (for similarity / RAG)
NVIDIA_EMBED_MODEL=nvidia/nv-embedqa-e5-v5

# ── Algorithm Flags ───────────────────────
# Set to 'true' to enable each advanced algorithm
ENABLE_TEMPORAL_ANALYSIS=true
ENABLE_ANOMALY_DETECTION=true
ENABLE_SURVIVAL_RISK=true
ENABLE_XGBOOST_SCORER=true
ENABLE_PPO_TREATMENT=true
ENABLE_NVIDIA_LLM=true

# ── Server ────────────────────────────────
PORT=5000
LOG_LEVEL=INFO
