# AVIRA Environment Configuration
# Copy this file to .env and fill in real values for production.

APP_ENV=development
SECRET_KEY=avira-super-secret-key-replace-in-production
PORT=5000
LOG_LEVEL=INFO
CORS_ORIGINS=*

# AI Tuning
AI_CONFIDENCE_THRESHOLD=0.35
AI_HIGH_CONFIDENCE=0.70

# Session
SESSION_TIMEOUT=30
